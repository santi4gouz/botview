#!/usr/bin/env sh
set -eu

cd "$(dirname "$0")"

echo "== Limax Bot Setup =="

install_node_runtime() {
  if command -v node >/dev/null 2>&1 && command -v npm >/dev/null 2>&1; then
    return 0
  fi

  echo "⚙️ Node.js/npm nao encontrados. Tentando instalar automaticamente..."

  if command -v pkg >/dev/null 2>&1; then
    pkg update -y
    pkg install -y nodejs-lts
  elif command -v apt-get >/dev/null 2>&1; then
    apt-get update -y
    apt-get install -y nodejs npm
  elif command -v apt >/dev/null 2>&1; then
    apt update -y
    apt install -y nodejs npm
  elif command -v apk >/dev/null 2>&1; then
    apk add --no-cache nodejs npm
  elif command -v dnf >/dev/null 2>&1; then
    dnf install -y nodejs npm
  elif command -v pacman >/dev/null 2>&1; then
    pacman -Sy --noconfirm nodejs npm
  else
    echo "❌ Nao encontrei gerenciador de pacotes suportado para instalar Node.js."
    echo "Instale Node 18+ manualmente e rode novamente."
    exit 1
  fi

  if ! command -v node >/dev/null 2>&1 || ! command -v npm >/dev/null 2>&1; then
    echo "❌ Falha ao instalar Node.js/npm automaticamente."
    exit 1
  fi
}

install_node_runtime

echo "📦 Instalando dependencias..."
npm install

echo "🚀 Iniciando bot..."
echo
echo "📱 O bot vai pedir o numero no proximo passo."
echo

npm start
